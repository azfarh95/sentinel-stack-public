{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Bare minimum Express 5.1 backend with TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --sourcemap",
    "build:watch": "tsup --watch",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "clean": "rm -rf dist",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:generate:dev": "dotenv -e ../../.env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:migrate:dev": "dotenv -e ../../.env.local -- drizzle-kit migrate"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.16.0",
    "@repo/trpc": "workspace:*",
    "@repo/zod-types": "workspace:*",
    "@trpc/server": "^11.17.0",
    "basic-auth": "^2.0.1",
    "better-auth": "^1.6.11",
    "cors": "^2.8.6",
    "cross-spawn": "^7.0.6",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "nanoid": "^5.1.11",
    "pg": "^8.21.0",
    "shell-quote": "^1.8.3",
    "spawn-rx": "^5.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@types/basic-auth": "^1.1.8",
    "@types/cors": "^2.8.19",
    "@types/cross-spawn": "^6.0.6",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/shell-quote": "^1.7.5",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}

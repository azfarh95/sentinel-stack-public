{
  "manifest_version": 3,
  "name": "Browser Assistant (Sentinel)",
  "short_name": "Browser Assistant",
  "description": "Drive an autonomous local-Qwen browser agent from a side panel — type a task, watch it work, approve clicks/types inline. Talks to the gated :8108 surface.",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Open Browser Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8108/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

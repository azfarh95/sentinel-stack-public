{
  "manifest_version": 3,
  "name": "OpenClaw Sidepanel",
  "short_name": "OpenClaw",
  "description": "Chat with your local OpenClaw / Qwen agent inside Comet. The agent can act on the current tab via Playwright MCP.",
  "version": "0.1.0",
  "minimum_chrome_version": "114",
  "action": {
    "default_title": "Open OpenClaw sidepanel",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8101/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

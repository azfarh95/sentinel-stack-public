# Sentinel claude-assistant testbot — Claude → user dev pings
TESTBOT_TOKEN=__WCM_testbot_token__

# SM-DL bot token
SMDL_BOT_TOKEN=__WCM_smdl_bot_token__

# GitHub MCP
GITHUB_PAT=__WCM_github_pat__

# OneDrive MCP
ONEDRIVE_CLIENT_SECRET=__WCM_onedrive_client_secret__

# Azure Document Intelligence (used by onedrive-mcp for PDF parsing)
DOCINTEL_KEY=__WCM_docintel_key__

# Vaultwarden self-hosted password manager admin token
# Used to access /admin panel at http://127.0.0.1:8085/admin
VAULTWARDEN_ADMIN_TOKEN=__WCM_vaultwarden_admin_token__

# Sentinel Suite cookie-auth shim — HMAC-signed cookie on .az-sentinel.xyz
# (90-day TTL). Consumers: sentinel-vpn-dashboard (compose env),
# sentinel-miniapp-v2 bridge.py (WCM fallback). Rotate via
# scripts/rotate_owner_auth_token.ps1 (never echo to chat).
OWNER_AUTH_TOKEN=__WCM_owner_auth_token__

# Telethon user-account session (used by smdl for >50 MB file uploads via MTProto,
# and by sentinel-miniapp for the chat-composer feature). 2 GB upload cap on
# Telethon vs 50 MB on the bot API.
TELETHON_API_ID=__WCM_telethon_api_id__
TELETHON_API_HASH=__WCM_telethon_api_hash__
TELETHON_SESSION=__WCM_telethon_session__

# SMDL signed-share secret — HMAC key for /share/<token>/<file> URLs that
# expose recordings publicly via Cloudflare Tunnel with time-limited tokens.
# 64-char hex; rotating it invalidates all existing share links.
SMDL_SHARE_SECRET=__WCM_smdl_share_secret__

# ── Sentinel Finance auth (portfolio-mcp) ────────────────────────────────────

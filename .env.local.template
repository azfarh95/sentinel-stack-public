# Moralis Web3 API key (read by portfolio-mcp for multi-chain wallet snapshots).
MORALIS_API_KEY=__WCM_moralis_api_key__

# Etherscan v2 API key (read by portfolio-mcp for historical EVM tx on Eth/BSC/

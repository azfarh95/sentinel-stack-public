#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Then store via:
#   python -c "import keyring; keyring.set_password('sentinel-miniapp','sentinel_finance_agent_token','<value>')"
SENTINEL_FINANCE_AGENT_TOKEN=__WCM_sentinel_finance_agent_token__


# Redirect URI must be: https://sentinelfinance.az-sentinel.xyz/auth/callback
GOOGLE_CLIENT_ID=__WCM_google_client_id__
GOOGLE_CLIENT_SECRET=__WCM_google_client_secret__

# Firefly III Personal Access Token (read by portfolio-mcp for balance sheet).

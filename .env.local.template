# Generated by scripts/sync_env_from_wcm.ps1
# Secrets are pulled from Windows Credential Manager (service: sentinel-miniapp)
# Edit this template, run sync, do NOT commit .env.local with real secrets.

NODE_ENV=production
LOG_LEVEL=all

# ============================================================================
# POSTGRES CONNECTION DETAILS
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=metamcp_user
# Pulled from WCM (sentinel-metamcp:postgres_password) — NOT a hardcoded literal.
# The old hardcoded `m3t4mcp` was STALE (real pw is 28 chars, baked in the
# metamcp-pg volume); every sync clobbered .env.local back to the dev default,
# and on the next restart the brain bot + bridge lost DB auth (2026-06-15 incident).
# Rotating = ALTER USER metamcp_user + update WCM + recreate `app` + restart bot.
POSTGRES_PASSWORD=__WCM_postgres_password__
POSTGRES_DB=metamcp_db

# Database connection URL (auto-composed from above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ============================================================================
# APPLICATION URL CONFIGURATION
# ============================================================================
# WARNING: MetaMCP enforces CORS policy on APP_URL.
# You must access MetaMCP ONLY through this URL.
# For local development on Windows + Docker Desktop: use http://localhost:12008
# Do NOT use 127.0.0.1 or host.docker.internal for client connections.
APP_URL=http://localhost:12008
NEXT_PUBLIC_APP_URL=http://localhost:12008

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================
# BETTER_AUTH_SECRET: Used for session encryption and security.
# REQUIRED: Replace with the generated secret below or provide your own.
# Generated secret: 874any1sY8nCFX2aSxs49Iyl/5YLfDhcqgEMfYjpVCA=
# IMPORTANT: Do NOT commit this to version control. Use a secure method to provide it.
BETTER_AUTH_SECRET=__WCM_better_auth_secret__

# ============================================================================
# DOCKER NETWORKING FIX
# ============================================================================
# Allows the container to resolve localhost to host.docker.internal if needed
TRANSFORM_LOCALHOST_TO_DOCKER_INTERNAL=true

# ============================================================================
# BOOTSTRAP CONFIGURATION
# ============================================================================
# These settings configure initial users, API keys, namespaces, and endpoints
# on startup. Customize to your needs.

BOOTSTRAP_ENABLE=true
BOOTSTRAP_FAIL_HARD=false
BOOTSTRAP_DEBUG=false

# Single User Configuration (for local development)
BOOTSTRAP_USER_EMAIL=admin@localhost
BOOTSTRAP_USER_NAME=Administrator
BOOTSTRAP_USER_PASSWORD=eKdmXrvrvT0xs^2A

# User Management Options
BOOTSTRAP_WARN_PASSWORD_CHANGE=true
BOOTSTRAP_RECREATE_USER=false
BOOTSTRAP_DELETE_OTHER_USERS=false
BOOTSTRAP_PRESERVE_API_KEYS=true
BOOTSTRAP_ONLY_FIRST_RUN=false

# Registration Controls
BOOTSTRAP_DISABLE_REGISTRATION_UI=false
BOOTSTRAP_DISABLE_REGISTRATION_SSO=true

# ============================================================================
# API KEYS CONFIGURATION
# ============================================================================
# Bootstrapped API keys for clients to authenticate.
# Format: [{"name":"key_name","is_public":true_or_false,"user_email":"user@example.com"}]
BOOTSTRAP_API_KEYS=[{"name":"LM Studio","is_public":false},{"name":"OpenClaw","is_public":false}]

# ============================================================================
# NAMESPACES CONFIGURATION
# ============================================================================
# Namespaces group MCP servers and allow for per-namespace settings.
# Recommended: Create separate namespaces for different tool sets.
BOOTSTRAP_NAMESPACES=[{"name":"Default","description":"Default namespace","is_public":true,"update":true},{"name":"Cloud Tools","description":"Google Drive, OneDrive, and cloud integrations","is_public":true,"update":true}]

# ============================================================================
# ENDPOINTS CONFIGURATION
# ============================================================================
# Endpoints are the public-facing URLs that clients (LM Studio, OpenClaw) connect to.
# Each endpoint is backed by one namespace containing aggregated MCP servers.
#
# Format: [{"name":"endpoint_name","namespace":"namespace_name","enable_auth":true/false,...}]
# 
# Authentication Options:
#  - enable_auth: Require API key in Authorization header or query param
#  - enable_auth_query: Allow API key in ?api_key=... (not recommended for SSE)
#  - enable_auth_oauth: Enable OAuth/OIDC authentication
#
# Transport: MetaMCP exposes endpoints via:
#  - SSE: http://localhost:12008/metamcp/{endpoint_name}/sse
#  - HTTP: http://localhost:12008/metamcp/{endpoint_name}/mcp
#  - OpenAPI: http://localhost:12008/metamcp/{endpoint_name}/openapi
BOOTSTRAP_ENDPOINTS=[{"name":"default","description":"Default endpoint (all tools)","namespace":"Default","enable_auth":true,"enable_auth_query":false,"enable_auth_oauth":false,"is_public":false,"update":true},{"name":"cloud","description":"Cloud storage and integrations endpoint","namespace":"Cloud Tools","enable_auth":true,"enable_auth_query":false,"enable_auth_oauth":false,"is_public":false,"update":true}]

# ============================================================================
# OPTIONAL: OIDC / SSO CONFIGURATION
# ============================================================================
# For production deployments, consider enabling OIDC for centralized authentication.
# Uncomment and configure as needed.
#
# OIDC_CLIENT_ID=your-oidc-client-id
# OIDC_CLIENT_SECRET=your-oidc-client-secret
# OIDC_DISCOVERY_URL=https://your-provider/.well-known/openid-configuration
# OIDC_PROVIDER_ID=oidc
# OIDC_SCOPES=openid email profile
# OIDC_PKCE=true

# ============================================================================
# OPTIONAL: EXTRA TRUSTED ORIGINS
# ============================================================================
# Useful for cluster deployments. Comma-separated list of origins.
# EXTRA_TRUSTED_ORIGINS=http://myapp.example.com,http://myapp.example.com:8080

# Telegram bot token (Sentinel / maps / reminders / ytdlp)
TELEGRAM_BOT_TOKEN=__WCM_telegram_bot_token__

# Sentinel claude-assistant testbot — Claude → user dev pings
TESTBOT_TOKEN=__WCM_testbot_token__

# SM-DL bot token
SMDL_BOT_TOKEN=__WCM_smdl_bot_token__

# GitHub MCP
GITHUB_PAT=__WCM_github_pat__

# OneDrive MCP
ONEDRIVE_CLIENT_SECRET=__WCM_onedrive_client_secret__

# Azure Document Intelligence (used by onedrive-mcp for PDF parsing)
DOCINTEL_KEY=__WCM_docintel_key__

# Vaultwarden self-hosted password manager admin token
# Used to access /admin panel at http://127.0.0.1:8085/admin
VAULTWARDEN_ADMIN_TOKEN=__WCM_vaultwarden_admin_token__

# Sentinel Suite cookie-auth shim — HMAC-signed cookie on .az-sentinel.xyz
# (90-day TTL). Consumers: sentinel-vpn-dashboard (compose env),
# sentinel-miniapp-v2 bridge.py (WCM fallback). Rotate via
# scripts/rotate_owner_auth_token.ps1 (never echo to chat).
OWNER_AUTH_TOKEN=__WCM_owner_auth_token__

# Telethon user-account session (used by smdl for >50 MB file uploads via MTProto,
# and by sentinel-miniapp for the chat-composer feature). 2 GB upload cap on
# Telethon vs 50 MB on the bot API.
TELETHON_API_ID=__WCM_telethon_api_id__
TELETHON_API_HASH=__WCM_telethon_api_hash__
TELETHON_SESSION=__WCM_telethon_session__

# SMDL signed-share secret — HMAC key for /share/<token>/<file> URLs that
# expose recordings publicly via Cloudflare Tunnel with time-limited tokens.
# 64-char hex; rotating it invalidates all existing share links.
SMDL_SHARE_SECRET=__WCM_smdl_share_secret__

# SMDL license-authority HMAC key — signs the bearer `secret` of every issued
# license key (SMDL-FAM / SMDL-COM). Only HMAC-SHA256(this, secret) is stored in
# jobs.db, so a DB leak yields no usable keys. CRITICAL: this value must stay
# STABLE forever — rotating it invalidates the HMAC of every key already issued,
# so previously-handed-out keys would fail /api/license/validate. Decoupled from
# OWNER_AUTH_TOKEN on purpose so token rotation never breaks live licenses.
LICENSE_SIGNING_SECRET=__WCM_license_signing_secret__

# Dedicated service token SMDL uses to mirror issued/revoked license keys to
# the central Sentinel License Registry (watchdog v2 /api/v2/licenses/*). Sent
# as X-Sentinel-Service-Token. Scoped to SMDL: revoking this entry from
# watchdog's config.json service_tokens map cuts SMDL's registry access without
# touching the Tauri/bridge tokens. Mirror is best-effort — absence just leaves
# keys local-only.
LICENSE_REGISTRY_TOKEN=__WCM_license_registry_token__

# Loopback-only token gating /internal/reload-env across every Sentinel
# consumer that participates in the #27 fanout (watchdog v2, smdl, bridge,
# finance, shared brain). sentinel-secrets writes secrets to .env.local
# then POSTs each consumer's reload endpoint with this token in
# X-Internal-Reload-Token. 64-char hex; rotation invalidates the fanout
# until every consumer re-reads the new value.
INTERNAL_RELOAD_TOKEN=__WCM_internal_reload_token__

# ── Sentinel Finance auth (portfolio-mcp) ────────────────────────────────────
# Google OAuth 2.0 web client used for sign-in at sentinelfinance.az-sentinel.xyz.
# Created at console.cloud.google.com/apis/credentials.
# Redirect URI must be: https://sentinelfinance.az-sentinel.xyz/auth/callback
GOOGLE_CLIENT_ID=__WCM_google_client_id__
GOOGLE_CLIENT_SECRET=__WCM_google_client_secret__

# Firefly III Personal Access Token (read by portfolio-mcp for balance sheet).
FIREFLY_PAT=__WCM_firefly_pat__

# Moralis Web3 API key (read by portfolio-mcp for multi-chain wallet snapshots).
MORALIS_API_KEY=__WCM_moralis_api_key__

# Etherscan v2 API key (read by portfolio-mcp for historical EVM tx on Eth/BSC/
# Base/Arbitrum/Polygon/Avalanche/Optimism — one key, 60+ chains via chainid param).
# Free tier: 5 calls/sec, 100k calls/day shared across all chains.
ETHERSCAN_API_KEY=__WCM_etherscan_api_key__

# Cronos EVM Explorer API key (replaces deprecated Cronoscan, custom v1 API
# at explorer-api.cronos.org/mainnet/api/v1/). Free key from
# https://explorer.cronos.org/register.
CRONOS_EXPLORER_API_KEY=__WCM_cronos_explorer_api_key__

# Wise API token (read-only personal token). Pulls balances + transactions.
WISE_API_TOKEN=__WCM_wise_api_token__

# Bearer token for /api/agent/* read-only endpoints. Consumer: Sentinel AI
# (@AZ_Sentinel_bot via OpenClaw / MetaMCP fetch-mcp). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Then store via:
#   python -c "import keyring; keyring.set_password('sentinel-miniapp','sentinel_finance_agent_token','<value>')"
SENTINEL_FINANCE_AGENT_TOKEN=__WCM_sentinel_finance_agent_token__

# Default EVM wallet address used by portfolio-mcp when no address is passed.
# Public address — fine to keep in template (not a secret).
PORTFOLIO_DEFAULT_ADDRESS=0xd8735ad8dba694f21c0ebc544ef908aeae56d751

# ── VPN exit-node (profile: vpn) ─────────────────────────────────────────────

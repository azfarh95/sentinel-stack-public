PIA_PASSWORD=__WCM_pia_password__
PIA_REGION=__WCM_pia_region__
PIA_DEDICATED_IP_TOKEN=__WCM_pia_dedicated_ip_token__
TS_AUTHKEY_PIA_EXIT=__WCM_ts_authkey_pia_exit__

# ── Coinbox arcade (public Credits economy; profile coinbox; ../coinbox-credits, D-018) ──
# Secrets per the sentinel-watchdog manifest (coinbox-db-password / coinbox-session-secret /
# coinbox-bot-token, all WCM service sentinel-miniapp). WITHOUT these synced here, the PUBLIC
# arcade silently falls back to the insecure compose dev defaults — and the DB-password drift
# crash-loops coinbox-credits (auth failed for user "coinbox"). They MUST be synced.
# COINBOX_GPU_BROKER_TOKEN mirrors the watchdog gpu-broker-client token (a DIFFERENT WCM
# service — fetched cross-service by sync_env_from_wcm.ps1's $crossServiceKeys map).
# COINBOX_DB_PASSWORD is baked into the coinbox_db volume: rotating it needs
# ALTER USER coinbox PASSWORD inside coinbox-postgres, then re-sync + recreate coinbox-credits.
COINBOX_DB_PASSWORD=__WCM_coinbox_db_password__
COINBOX_SESSION_SECRET=__WCM_coinbox_session_secret__
COINBOX_BOT_TOKEN=__WCM_coinbox_bot_token__
COINBOX_GPU_BROKER_TOKEN=__WCM_coinbox_gpu_broker_token__

